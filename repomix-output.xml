import { Graphics } from 'pixi.js';


export class Constants {
	constructor() {
		this.DAMPING = .03;
		this.DRAG = .995;
		this.GRAVITY = 980;
		this.FIXED_TIME_STEP = 1 / 60;
		this.DEFAULT_COLUMNS = 60;
		this.DEFAULT_COLUMNS_MOBILE = 40;
		this.DEFAULT_ROWS = 30;
		this.DEFAULT_ROWS_MOBILE = 30;
		this.DEFAULT_PINS = 7;
		this.DEFAULT_PINS_MOBILE = 5;
		this.GRAB_RADIUS = 30;
		this.GRAB_RADIUS_MOBILE = 60;
		this.PARTICLE_RADIUS = 3;
		this.PARTICLE_RADIUS_MOBILE = 2;
		this.LINE_THICKNESS = 2;
		this.LINE_THICKNESS_MOBILE = 1;
		this.MOBILE_BREAKPOINT = 800;
	}
}

export class Globals {
	constructor() {
		this.vertex_holder = [];
		this.line_holder = [];
		this.line_count = 0;
		this.particle_holder = [];
		this.all_lines_graphics = new Graphics();
		this.particle_container;
